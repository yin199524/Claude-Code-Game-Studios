; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Zen Legion"
config/description="禅意军团 - 回合制自动战斗游戏"
config/version="0.1.0"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Global="*res://src/global.gd"
GameManager="*res://src/autoload/game_manager.gd"
SaveManager="*res://src/autoload/save_manager.gd"
UnitDatabase="*res://src/autoload/unit_database.gd"
LevelDatabase="*res://src/autoload/level_database.gd"
SceneTransition="*res://src/autoload/scene_transition.gd"
ParticleEffects="*res://src/autoload/particle_effects.gd"
SoundManager="*res://src/autoload/sound_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=720
window/size/window_height_override=1280
window/stretch/mode="canvas_items"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[input]

[rendering]

renderer/rendering_method="forward_plus"

[gut]

file_prefix="test_"
file_extension=".gd"
file_suffix=".gd"
inner_class_prefix="Test"
dirs=PackedStringArray("res://tests/unit/")
ignore_pauses=false
log_level=2
compact_mode=false
show_orphans=true
